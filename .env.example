# Copy this file to .env on the VPS (NOT committed to git) and fill in real values.
# Used by docker-compose.yml at the repo root when deploying on Hostinger.

SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=replace-with-16-char-gmail-app-password
CONTACT_TO=where-to-receive-messages@example.com
CORS_ORIGIN=https://complexe-scolaire-afrika.com,https://www.complexe-scolaire-afrika.com
VITE_API_URL=https://api.complexe-scolaire-afrika.com
